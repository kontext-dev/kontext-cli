{
  "name": "@kontext-dev/cli",
  "version": "0.1.0",
  "description": "Kontext CLI — governed agent sessions for Claude Code",
  "type": "module",
  "bin": {
    "kontext": "./dist/bin.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/bin.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "check-types": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "open": "^10.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.18.0",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "license": "MIT"
}
